---
import '../styles/main.less';

interface Props {
  title: string;
  bodyClass?: string;
}

const { title, bodyClass = '' } = Astro.props;

const navLinks = [
  { href: '/',         label: 'Home',     cls: 'home-link'     },
  { href: '/about',    label: 'About',    cls: 'about-link'    },
  { href: '/projects', label: 'Projects', cls: 'projects-link' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sreenath Somarajapuram - Software Engineer" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="prefetch" href="/images/bg-header.jpg" />
  </head>

  <body class={`landscape ${bodyClass}`}>

    <div class="main-container">

      <div class="header outer-block">
        <div class="inner-block">
          <a class="index-link" href="/">
            <img class="logo" src="/images/ss.png" alt="SS" />
            <span class="name">&nbsp;Sreenath Somarajapuram</span>
          </a>
          <div class="menu">
            {navLinks.map(({ href, label, cls }) => (
              <a class={cls} href={href}>{label}</a>
            ))}
          </div>
        </div>
      </div>

      <slot />

      <div class="footer outer-block">
        <div class="inner-block">
          <div class="small-text">
            &copy; {new Date().getFullYear()} Sreenath Somarajapuram
          </div>
          <div class="menu float-right">
            {navLinks.map(({ href, label }) => (
              <a href={href} class="hover-black">{label}</a>
            ))}
          </div>
          <a class="scroll-top hover-black" href="#top">&#8682;</a>
        </div>
      </div>

    </div>

  </body>
</html>

<script>
  import { initScrollTop } from '../scripts/loader';

  initScrollTop();
</script>
