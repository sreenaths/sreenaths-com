---
import '../styles/main.less';

interface Props {
  title: string;
  bodyClass?: string;
}

const { title, bodyClass = '' } = Astro.props;

const navLinks = [
  { href: '/',         label: 'home',     cls: 'home-link'     },
  { href: '/about',    label: 'about',    cls: 'about-link'    },
  { href: '/projects', label: 'projects', cls: 'projects-link' },
  { href: '/contacts', label: 'contacts', cls: 'contacts-link' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sreenath Somarajapuram - Software Engineer" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="prefetch" href="/images/loader.gif" />
    <link rel="prefetch" href="/images/bg-header.jpg" />
  </head>

  <body class={`landscape ${bodyClass}`}>

    <div class="loading-msg">
      <img src="/images/ss.png" alt="" />
      Loading<br />
      <img src="/images/loader.gif" alt="" />
    </div>

    <div class="main-container">

      <div class="header outer-block">
        <div class="inner-block">
          <a class="index-link" href="/">
            <img class="logo" src="/images/ss.png" alt="SS" />
            <span class="name">&nbsp;Sreenath Somarajapuram</span>
          </a>
          <div class="menu">
            {navLinks.map(({ href, label, cls }) => (
              <a class={cls} href={href}>{label}</a>
            ))}
          </div>
        </div>
      </div>

      <slot />

      <div class="footer outer-block">
        <div class="inner-block">
          <div class="small-text">
            &copy; {new Date().getFullYear()} Sreenath Somarajapuram
          </div>
          <div class="menu float-right">
            {navLinks.map(({ href, label }) => (
              <a href={href} class="hover-black">{label}</a>
            ))}
          </div>
          <a class="scroll-top hover-black" href="#top">&#8682;</a>
        </div>
      </div>

    </div>

  </body>
</html>

<script>
  function isMobile(): boolean {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry/i.test(navigator.userAgent);
  }

  function initLoaderAnim(): void {
    const loader = document.querySelector<HTMLElement>('.loading-msg');
    const container = document.querySelector<HTMLElement>('.main-container');
    if (!loader || !container) return;

    loader.style.display = 'block';
    container.style.display = 'none';

    function onLoad(): void {
      loader.style.transition = 'opacity 0.3s';
      loader.style.opacity = '0';
      setTimeout(() => {
        loader.style.display = 'none';
        container.style.opacity = '0';
        container.style.display = 'block';
        container.style.transition = 'opacity 0.5s';
        requestAnimationFrame(() => {
          container.style.opacity = '1';
        });
      }, 300);
    }

    if (document.readyState === 'complete') {
      onLoad();
    } else {
      window.addEventListener('load', onLoad);
    }
  }

  function initScrollTop(): void {
    document.querySelector('.scroll-top')?.addEventListener('click', (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  initLoaderAnim();
  initScrollTop();
</script>
